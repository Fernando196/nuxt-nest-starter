{
  "name": "nuxt-nest-starter",
  "version": "0.1.0",
  "description": "CLI tool to create a Nuxt.js and Nest.js project",
  "type": "commonjs",
  "main": "cli/dist/index.js",
  "bin": {
    "nuxt-nest-starter": "cli/dist/index.js"
  },
  "files": [
    "cli/dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p cli/tsconfig.json",
    "prepare": "tsc -p cli/tsconfig.json",
    "dev": "tsc -p cli/tsconfig.json --watch",
    "start": "node cli/dist/index.js"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.2.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
